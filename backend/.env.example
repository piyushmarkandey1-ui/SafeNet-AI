# ──────────────────────────────────────────────
# SafeNet AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Fireworks AI (AMD-hosted inference) ───────
# Primary LLM provider — runs on AMD Instinct GPUs
# Get your key: https://fireworks.ai/
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── Google Gemini (fallback) ───────────────────
# Used when Fireworks AI is unavailable
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OpenAI (secondary fallback) ───────────────
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── General ────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

# ── ChromaDB ───────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Frontend (local dev only) ──────────────────
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_DIST_PATH=../frontend/dist
