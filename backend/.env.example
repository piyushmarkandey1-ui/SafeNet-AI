# ──────────────────────────────────────────────
# SafeNet AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# General
APP_ENV=development
LOG_LEVEL=info

# OpenAI / LLM (for orchestrator & chatbot)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Google Maps / Geospatial (if needed)
GOOGLE_MAPS_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
