# Vercel Ignore File - Exclude from deployment

# Development files
backend/.pytest_cache/
backend/__pycache__/
backend/**/__pycache__/
backend/.venv/
backend/venv/
frontend/node_modules/
.git/
.vscode/

# Data files
data/raw/
data/synthetic/
*.csv
*.json.gz

# Model files (too large for Vercel)
backend/app/counterfeit_vision/models/*.pth
backend/app/counterfeit_vision/models/*.onnx
*.pt
*.pth
*.h5
*.pkl

# Logs and temporary files
*.log
*.tmp
*.temp
backend/orchestrator/audit_log.jsonl
backend/orchestrator/reports/

# Test files
backend/tests/
backend/scripts/test_*.py
backend/scripts/verify_*.py

# Documentation (not needed in deployment)
*.md
!README.md

# IDE files
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
