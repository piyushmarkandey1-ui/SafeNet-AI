# ──────────────────────────────────────────────
# SafeNet AI — .gitignore
# ──────────────────────────────────────────────

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ─── Virtual Environments ───
.venv/
venv/
env/
ENV/

# ─── Environment Variables ───
.env
.env.local
.env.*.local

# ─── Node / Frontend ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Vite / Build ───
frontend/dist/
frontend/.vite/

# ─── IDE / Editor ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───
.DS_Store
Thumbs.db
desktop.ini

# ─── ML / Models ───
*.pt
*.pth
*.onnx
*.tflite
!models/.gitkeep

# ─── Data (keep synthetic, ignore large real datasets) ───
data/raw/
data/processed/
data/reports/
backend/app/orchestrator/audit_log.jsonl
*.parquet
*.h5

# ─── Misc ───
*.log
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
