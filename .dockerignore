**/*.jpg

# Docs
docs/
*.md
!README.md

# Generated reports (written at runtime, not needed in image)
data/reports/

# Environment files (secrets — NEVER in image)
.env
backend/.env
**/.env

# Vercel artefacts
.vercelignore
vercel.json

# IDE
.vscode/
.kiro/
.agents/
